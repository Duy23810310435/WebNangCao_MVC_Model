@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<WebNangCao_MVC_Model.SharedResource> Localizer

@{
    ViewData["Title"] = Localizer["LpTitle"];
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@Localizer["LpTitle"]</title>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="~/css/LandingPage.css" />
</head>
<body>

    <header class="navbar">
        <div class="container nav-container">
            <div class="logo">
                <div class="logo-icon"><i data-lucide="graduation-cap"></i></div>
                <span class="logo-text">EduTest Pro</span>
            </div>
            <nav class="nav-links">
                <a href="#features">@Localizer["LpNavFeatures"]</a>
                <a href="#about">@Localizer["LpNavAbout"]</a>
                <a asp-controller="Home" asp-action="GetStarted" class="btn btn-primary">@Localizer["LpBtnStartNow"] <i data-lucide="arrow-right"></i></a>
            </nav>
        </div>
    </header>

    <main>
        <section class="hero">
            <div class="container hero-container">
                <div class="hero-content">
                    <div class="badge">
                        <i data-lucide="award"></i> @Localizer["LpHeroBadge"]
                    </div>
                    <h1>@Localizer["LpHeroTitle"]</h1>
                    <p>@Localizer["LpHeroDesc"]</p>

                    <div class="hero-buttons">
                        <a asp-controller="Home" asp-action="GetStarted" class="btn btn-primary">@Localizer["LpBtnStartNow"] <i data-lucide="arrow-right"></i></a>
                        <a asp-controller="Home" asp-action="DemoExam" class="btn btn-outline">@Localizer["LpBtnDemo"]</a>
                    </div>

                    <div class="hero-stats">
                        <div class="stat">
                            <h3>10K+</h3>
                            <p>@Localizer["LpStatCandidates"]</p>
                        </div>
                        <div class="stat">
                            <h3>500+</h3>
                            <p>@Localizer["LpStatTeachers"]</p>
                        </div>
                        <div class="stat">
                            <h3>50K+</h3>
                            <p>@Localizer["LpStatExams"]</p>
                        </div>
                    </div>
                </div>

                <div class="hero-image">
                    <div class="mockup-card">
                        <div class="mockup-header">
                            <div class="mockup-icon"><i data-lucide="check-circle-2"></i></div>
                            <div>
                                <h4>@Localizer["LpMockupTitle"]</h4>
                                <span>@Localizer["LpMockupStatus"]</span>
                            </div>
                        </div>
                        <div class="mockup-progress">
                            <div class="progress-info">
                                <span>@Localizer["LpMockupComplete"]</span>
                                <span>75%</span>
                            </div>
                            <div class="progress-bar"><div class="progress-fill"></div></div>
                        </div>
                        <div class="mockup-details">
                            <div class="detail-box">
                                <span>@Localizer["LpMockupQuestions"]</span>
                                <strong>30/40</strong>
                            </div>
                            <div class="detail-box">
                                <span>@Localizer["LpMockupTime"]</span>
                                <strong class="text-green">25:30</strong>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section id="features" class="features">
            <div class="container">
                <div class="section-header">
                    <h2>@Localizer["LpFeaturesTitle"]</h2>
                    <p>@Localizer["LpFeaturesDesc"]</p>
                </div>

                <div class="features-grid">
                    <div class="feature-card">
                        <div class="feature-icon bg-blue-light text-blue"><i data-lucide="book-open"></i></div>
                        <h3>@Localizer["LpFeat1Title"]</h3>
                        <p>@Localizer["LpFeat1Desc"]</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon bg-green-light text-green"><i data-lucide="laptop"></i></div>
                        <h3>@Localizer["LpFeat2Title"]</h3>
                        <p>@Localizer["LpFeat2Desc"]</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon bg-purple-light text-purple"><i data-lucide="bar-chart-2"></i></div>
                        <h3>@Localizer["LpFeat3Title"]</h3>
                        <p>@Localizer["LpFeat3Desc"]</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon bg-red-light text-red"><i data-lucide="shield-check"></i></div>
                        <h3>@Localizer["LpFeat4Title"]</h3>
                        <p>@Localizer["LpFeat4Desc"]</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon bg-yellow-light text-yellow"><i data-lucide="zap"></i></div>
                        <h3>@Localizer["LpFeat5Title"]</h3>
                        <p>@Localizer["LpFeat5Desc"]</p>
                    </div>
                    <div class="feature-card">
                        <div class="feature-icon bg-blue-light text-blue"><i data-lucide="users"></i></div>
                        <h3>@Localizer["LpFeat6Title"]</h3>
                        <p>@Localizer["LpFeat6Desc"]</p>
                    </div>
                </div>
            </div>
        </section>

        <section id="about" class="about">
            <div class="container">
                <div class="section-header">
                    <h2>@Localizer["LpAboutTitle"]</h2>
                    <p>@Localizer["LpAboutDesc"]</p>
                </div>
                <div class="about-stats">
                    <div class="stat-item">
                        <h3>5+</h3>
                        <p>@Localizer["LpAboutExp"]</p>
                    </div>
                    <div class="stat-item">
                        <h3>100+</h3>
                        <p>@Localizer["LpAboutSchools"]</p>
                    </div>
                    <div class="stat-item">
                        <h3>99.9%</h3>
                        <p>@Localizer["LpAboutReliability"]</p>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <footer class="footer">
        <div class="container footer-grid">
            <div class="footer-brand">
                <div class="logo">
                    <div class="logo-icon"><i data-lucide="graduation-cap"></i></div>
                    <span class="logo-text">EduTest Pro</span>
                </div>
                <p>@Localizer["LpFooterDesc"]</p>
            </div>
            <div class="footer-links">
                <h4>@Localizer["LpFooterQuickLinks"]</h4>
                <ul>
                    <li><a href="#">@Localizer["LpFooterAboutUs"]</a></li>
                    <li><a href="#">@Localizer["LpNavFeatures"]</a></li>
                    <li><a href="#">@Localizer["LpFooterPricing"]</a></li>
                    <li><a href="#">@Localizer["LpFooterSupport"]</a></li>
                </ul>
            </div>
            <div class="footer-links">
                <h4>@Localizer["LpFooterResources"]</h4>
                <ul>
                    <li><a href="#">@Localizer["LpFooterDocs"]</a></li>
                    <li><a href="#">@Localizer["LpFooterVideo"]</a></li>
                    <li><a href="#">@Localizer["LpFooterBlog"]</a></li>
                    <li><a href="#">@Localizer["LpFooterFAQ"]</a></li>
                </ul>
            </div>
            <div class="footer-contact">
                <h4>@Localizer["LpFooterContact"]</h4>
                <ul>
                    <li><i data-lucide="mail"></i> support@edutest.vn</li>
                    <li><i data-lucide="phone"></i> 1900 1234</li>
                    <li><i data-lucide="map-pin"></i> @Localizer["LpFooterAddress"]</li>
                </ul>
            </div>
        </div>
    </footer>

    <script>
        lucide.createIcons();
    </script>
</body>
</html>