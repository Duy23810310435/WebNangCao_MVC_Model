@model WebNangCao_MVC_Model.Models.AuthViewModels
@{
    ViewData["Title"] = Localizer["AuthTitle"];
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Localizer["AuthTitle"] - EduTest</title>
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
</head>
<body>

    <div class="auth-container">
        <div class="role-wrapper">
            <div class="role-dropdown" id="roleDropdown" onclick="toggleRoleList()">
                <div class="role-selected">
                    <div class="role-info">
                        <i data-lucide="user" id="current-role-icon" class="role-icon"></i>
                        <span id="current-role-text">@Localizer["RoleStudent"]</span>
                    </div>
                    <i data-lucide="chevron-down" class="role-arrow"></i>
                </div>

                <ul class="role-options" id="roleOptions">
                    <li onclick="selectRole('student', '@Localizer["RoleStudent"]', 'user')">
                        <i data-lucide="user" class="opt-icon"></i>
                        <span>@Localizer["RoleStudent"]</span>
                        <i data-lucide="check" class="check-icon" id="check-student"></i>
                    </li>

                    <li onclick="selectRole('instructor', '@Localizer["RoleInstructor"]', 'briefcase')">
                        <i data-lucide="briefcase" class="opt-icon"></i>
                        <span>@Localizer["RoleInstructor"]</span>
                        <i data-lucide="check" class="check-icon hidden" id="check-instructor"></i>
                    </li>
                    <li onclick="selectRole('admin', '@Localizer["RoleAdmin"]', 'shield')">
                        <i data-lucide="shield" class="opt-icon"></i>
                        <span>@Localizer["RoleAdmin"]</span>
                        <i data-lucide="check" class="check-icon hidden" id="check-admin"></i>
                    </li>
                </ul>
            </div>
        </div>

        <div class="auth-header">
            <div class="header-icon-box">
                <i data-lucide="graduation-cap" class="big-icon"></i>
            </div>
            <h1>EduTest</h1>
            <p>@Localizer["SystemDescription"]</p>
        </div>
        
        <div class="tabs">
            <button type="button" id="btn-tab-login" class="tab-btn @(Model.ActiveTab == "login" ? "active" : "")" onclick="switchTab('login')">
                <i data-lucide="log-in" class="tab-icon"></i> @Localizer["LoginTab"]
            </button>

            <button type="button" id="btn-tab-register" class="tab-btn @(Model.ActiveTab == "register" ? "active" : "")" onclick="switchTab('register')">
                <i data-lucide="user-plus" class="tab-icon"></i> @Localizer["RegisterTab"]
            </button>
        </div>

        <div id="tab-content-login" class="@(Model.ActiveTab == "login" ? "" : "hidden")">
            <form asp-controller="Account" asp-action="Login" method="post" novalidate>
                <input type="hidden" name="Role" id="input-role-login" value="student" />
                @if (!ViewData.ModelState.IsValid && Model.ActiveTab == "login")
                {
                    <div class="validation-summary">@Html.ValidationSummary(true)
                        @Localizer["AuthError"]
                    </div>
                }

                <div class="form-group">
                    <label class="form-label">@Localizer["UsernameOrEmail"]</label>
                    <div class="input-wrapper">
                        <i data-lucide="user" class="input-icon"></i>
                        <input asp-for="Login.UsernameOrEmail" class="form-input" placeholder="@Localizer["PlaceholderEmail"]" />
                    </div>
                    <span asp-validation-for="Login.UsernameOrEmail" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">@Localizer["Password"]</label>
                    <div class="input-wrapper">
                        <i data-lucide="lock" class="input-icon"></i>
                        <input asp-for="Login.Password" type="password" class="form-input" placeholder="@Localizer["PlaceholderPassword"]" />
                    </div>
                    <span asp-validation-for="Login.Password" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-submit">@Localizer["BtnLogin"]</button>
            </form>
        </div>

        <div id="tab-content-register" class="@(Model.ActiveTab == "register" ? "" : "hidden")">
            <form asp-controller="Account" asp-action="Register" method="post" novalidate>
                <input type="hidden" asp-for="Register.Role" id="input-role-register" value="student" />
                @if (!ViewData.ModelState.IsValid && Model.ActiveTab == "register")
                {
                    <div class="validation-summary"><span class="text-danger">@Localizer["RegisterError"]</span></div>
                }

                <div class="form-group">
                    <label class="form-label">@Localizer["FullName"]</label>
                    <div class="input-wrapper">
                        <i data-lucide="contact" class="input-icon"></i>
                        <input asp-for="Register.Name" class="form-input" placeholder="Nguyễn Văn A" />
                    </div>
                    <span asp-validation-for="Register.Name" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">@Localizer["Email"]</label>
                    <div class="input-wrapper">
                        <i data-lucide="mail" class="input-icon"></i>
                        <input asp-for="Register.Email" class="form-input" placeholder="email@example.com" />
                    </div>
                    <span asp-validation-for="Register.Email" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">@Localizer["Username"]</label>
                    <div class="input-wrapper">
                        <i data-lucide="user" class="input-icon"></i>
                        <input asp-for="Register.Username" class="form-input" placeholder="DuyCooking257" />
                    </div>
                    <span asp-validation-for="Register.Username" class="text-danger" ></span>
                </div>

                <div class="form-group">
                    <label class="form-label">@Localizer["Password"]</label>
                    <div class="input-wrapper">
                        <i data-lucide="lock" class="input-icon"></i>
                        <input asp-for="Register.Password" type="password" class="form-input" placeholder="@Localizer["PlaceholderPassword"]" />
                    </div>
                    <span asp-validation-for="Register.Password" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label class="form-label">@Localizer["ConfirmPassword"]</label>
                    <div class="input-wrapper">
                        <i data-lucide="shield-check" class="input-icon"></i>
                        <input asp-for="Register.ConfirmPassword" type="password" class="form-input" />
                    </div>
                    <span asp-validation-for="Register.ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn-submit">@Localizer["BtnRegister"]</button>
            </form>
        </div>
    </div>

    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="~/js/auth.js"></script>
    <script>
        lucide.createIcons();
    </script>
   
</body>
</html>