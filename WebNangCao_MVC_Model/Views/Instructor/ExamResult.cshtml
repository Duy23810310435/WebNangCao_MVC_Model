@using WebNangCao_MVC_Model.ViewModels
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<WebNangCao_MVC_Model.SharedResource> Localizer
@model ExamResultSummaryViewModel

@{
    ViewData["Title"] = Localizer["ResultTitle"];
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2><i class="fas fa-chart-bar"></i> @Localizer["ResultOf", Model.ExamTitle]</h2>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("Exams")" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> @Localizer["BtnBack"]
            </a>
        </div>
    </div>

    @if (Model.StudentResults.Any())
    {
        <div class="card shadow">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-primary">
                            <tr>
                                <th>@Localizer["ColStudentName"]</th>
                                <th>@Localizer["ColScore"]</th>
                                <th>@Localizer["ColSubmitTime"]</th>
                                <th>@Localizer["ColResult"]</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var result in Model.StudentResults.OrderByDescending(r => r.Score))
                            {
                                <tr>
                                    <td>@result.StudentName</td>
                                    <td>
                                        <strong class="@(result.Score >= 5 ? "text-success" : "text-danger")">
                                            @result.Score.ToString("F1")
                                        </strong>
                                    </td>
                                    <td>@result.SubmitTime.ToString("dd/MM/yyyy HH:mm:ss")</td>
                                    <td>
                                        <span class="badge @(result.Score >= 5 ? "bg-success" : "bg-danger")">
                                            @* Nếu status đang lưu tĩnh trong DB, có thể cần switch-case dịch tương tự file trước, 
                                               tạm thời render thẳng biến Status của model *@
                                            @result.Status 
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <h5>@Localizer["StatsHeader"]</h5>
            <div class="row">
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <div class="text-success">@Localizer["StatCompletedStudents"]</div>
                            <div class="h3">@Model.StudentResults.Count</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <div class="text-info">@Localizer["StatAvgScore"]</div>
                            <div class="h3">@Model.StudentResults.Average(r => r.Score).ToString("F1")</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <div class="text-success">@Localizer["StatPass"]</div>
                            <div class="h3">@Model.StudentResults.Count(r => r.Score >= 5)</div>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card">
                        <div class="card-body">
                            <div class="text-danger">@Localizer["StatFail"]</div>
                            <div class="h3">@Model.StudentResults.Count(r => r.Score < 5)</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <p>@Localizer["NoResultsMsg"]</p>
        </div>
    }
</div>