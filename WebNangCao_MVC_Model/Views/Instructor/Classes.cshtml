@using WebNangCao_MVC_Model.ViewModels
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<WebNangCao_MVC_Model.SharedResource> Localizer
@model List<ClassItemViewModel>

@{
    ViewData["Title"] = Localizer["ManageClassesTitle"];
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2><i class="fas fa-users"></i> @Localizer["ManageClassesTitle"]</h2>
        </div>
        <div class="col-md-4 text-end">
            <a href="@Url.Action("CreateClass")" class="btn btn-success">
                <i class="fas fa-plus"></i> @Localizer["BtnAddNewClass"]
            </a>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-primary">
                    <tr>
                        <th>@Localizer["ColClassName"]</th>
                        <th>@Localizer["ColDescription"]</th>
                        <th>@Localizer["ColStudentCount"]</th>
                        <th>@Localizer["ColActions"]</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cls in Model)
                    {
                        <tr>
                            <td><strong>@cls.GroupName</strong></td>
                            <td>@cls.Description</td>
                            <td><span class="badge bg-info">@cls.StudentCount</span></td>
                            <td>
                                <a href="@Url.Action("EditClass", new { id = cls.Id })" class="btn btn-sm btn-warning">
                                    <i class="fas fa-edit"></i> @Localizer["BtnEditClass"]
                                </a>
                                <form method="post" action="@Url.Action("DeleteClass", new { id = cls.Id })" style="display:inline;">
                                    <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('@Localizer["ConfirmDeleteClass"].Value')">
                                        <i class="fas fa-trash"></i> @Localizer["BtnDeleteClass"]
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <p>@Localizer["NoClassesMsg"] <a href="@Url.Action("CreateClass")">@Localizer["CreateNewClassLink"]</a></p>
        </div>
    }
</div>