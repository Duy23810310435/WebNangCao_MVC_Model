@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<WebNangCao_MVC_Model.SharedResource> Localizer
@model WebNangCao_MVC_Model.ViewModels.ReviewResultViewModel

<div class="review-container">
    <header class="review-header">
        <div class="score-circle">
            <span class="score-value" id="animatedScore" data-target="@Model.Score">0</span>
            <span class="score-label">@Localizer["ReviewScoreLabel"]</span>
        </div>
        <div class="summary-info">
            @{
                string resultType = Model.IsSelfCreated ? Localizer["ReviewResultDetailed"].Value : Localizer["ReviewResultExam"].Value;
            }
            <h1>@Localizer["ReviewTitle", resultType]</h1>
            <p>@Localizer["ReviewAttemptId"] <strong>#@Model.ResultId</strong></p>
            <div class="stats-grid">
                <div class="stat-item">
                    <span>@Localizer["ReviewCorrectAnswers"]</span>
                    <strong>@Model.Questions.Count(q => q.Answers.Any(a => a.IsCorrectAnswer && a.AnswerId == q.SelectedAnswerId)) / @Model.Questions.Count</strong>
                </div>
                <div class="stat-item">
                    <span>@Localizer["ReviewStatusLabel"]</span>
                    <strong class="status-pass">@Localizer["ReviewStatusCompleted"]</strong>
                </div>
            </div>

            <div class="action-buttons">
                @if (Model.IsSelfCreated)
                {
                    <button type="button" onclick="handlePostTest('RETAKE', @Model.TestId)" class="btn-back" style="background: #3b82f6; color: white; border: none;">
                        <i class="fas fa-redo"></i> @Localizer["ReviewBtnRetake"]
                    </button>
                    <button type="button" onclick="handlePostTest('SAVE', @Model.TestId)" class="btn-print" style="background: #64748b; color: white; border: none;">
                        <i class="fas fa-save"></i> @Localizer["ReviewBtnSave"]
                    </button>
                    <button type="button" onclick="handlePostTest('DELETE', @Model.TestId)" class="btn-print" style="background: #ef4444; color: white; border: none;">
                        <i class="fas fa-trash-alt"></i> @Localizer["ReviewBtnDeletePersonal"]
                    </button>
                }
                else
                {
                    <a href="@Url.Action("Dashboard", "Student")" class="btn-back" style="background: #3b82f6; color: white; border: none; text-decoration: none; display: inline-flex; align-items: center; gap: 8px;">
                        <i class="fas fa-home"></i> @Localizer["ReviewBtnHome"]
                    </a>
                    <button type="button" onclick="window.print()" class="btn-print" style="background: #64748b; color: white; border: none;">
                        <i class="fas fa-print"></i> @Localizer["ReviewBtnPrint"]
                    </button>
                }
            </div>
        </div>
    </header>

    <main class="question-list">
        @for (int i = 0; i < Model.Questions.Count; i++)
        {
            var q = Model.Questions[i];
            <section class="question-card">
                <div class="question-title">
                    <span class="q-number">@Localizer["ReviewQuestionNumber", i + 1]</span>
                    <p>@q.Content</p>
                </div>

                <div class="answer-options">
                    @foreach (var ans in q.Answers)
                    {
                        bool isUserSelected = (q.SelectedAnswerId == ans.AnswerId);
                        bool isCorrect = ans.IsCorrectAnswer;

                        string statusClass = "";
                        if (isCorrect) statusClass = "correct";
                        else if (isUserSelected && !isCorrect) statusClass = "wrong";

                        <div class="answer-item @statusClass">
                            <div class="custom-indicator">
                                @if (isCorrect)
                                {
                                    <span>✔</span>
                                }
                                else if (isUserSelected)
                                {
                                    <span>✖</span>
                                }
                            </div>
                            <span class="answer-text">@ans.Content</span>
                            @if (isUserSelected)
                            {
                                <span class="user-tag">@Localizer["ReviewYourChoice"]</span>
                            }
                        </div>
                    }
                </div>
            </section>
        }

        @if (Model.IsSelfCreated)
        {
            <div style="display: flex; justify-content: center; gap: 15px; margin-top: 40px; padding-bottom: 20px;">
                <button class="btn-print" style="background: #ef4444; color: white; border: none; padding: 12px 24px; border-radius: 8px; cursor: pointer;" onclick="handlePostTest('DELETE', @Model.TestId)">
                    <i class="fas fa-trash-alt"></i> @Localizer["ReviewBtnDeleteAll"]
                </button>
                <button class="btn-back" style="padding: 12px 24px; border-radius: 8px;" onclick="handlePostTest('SAVE', @Model.TestId)">
                    <i class="fas fa-arrow-left"></i> @Localizer["ReviewBtnSaveAndReturn"]
                </button>
            </div>
        }
    </main>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // Hiệu ứng nhảy số điểm
        const scoreElement = document.getElementById("animatedScore");
        if (scoreElement) {
            const target = parseFloat(scoreElement.getAttribute("data-target"));
            let current = 0;
            const increment = target / 50; 

            const updateScore = () => {
                if (current < target) {
                    current += increment;
                    scoreElement.innerText = current.toFixed(1);
                    setTimeout(updateScore, 20);
                } else {
                    scoreElement.innerText = target;
                }
            };
            updateScore();
        }

        // Hiệu ứng hover nhẹ vào các câu hỏi
        const cards = document.querySelectorAll(".question-card");
        cards.forEach(card => {
            card.addEventListener("mouseenter", () => {
                card.style.transform = "translateY(0px) Scale(1.02)";
                card.style.transition = "0.3s";
                card.style.boxShadow = "0 10px 15px -3px rgba(0, 0, 0, 0.1)";
            });
            card.addEventListener("mouseleave", () => {
                card.style.transform = "translateY(0) Scale(1)";
                card.style.boxShadow = "0 4px 6px -1px rgba(0, 0, 0, 0.1)";
            });
        });
    });
</script>

<link rel="stylesheet" href="~/css/review-result.css" />
<script src="~/js/review-result.js"></script>

@if (Model.IsSelfCreated)
{
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        //CHÈN BIẾN LOCALIZER XUỐNG JAVASCRIPT
        const swalTexts = {
            saveSuccessTitle: '@Html.Raw(Localizer["SwalSaveSuccessTitle"].Value)',
            saveSuccessText: '@Html.Raw(Localizer["SwalSaveSuccessText"].Value)',
            deleteWarnTitle: '@Html.Raw(Localizer["SwalDeleteWarningTitle"].Value)',
            deleteWarnText: '@Html.Raw(Localizer["SwalDeleteWarningText"].Value)',
            btnConfirmDelete: '@Html.Raw(Localizer["SwalBtnConfirmDelete"].Value)',
            btnCancel: '@Html.Raw(Localizer["SwalBtnCancel"].Value)',
            deleteSuccessTitle: '@Html.Raw(Localizer["SwalDeleteSuccessTitle"].Value)',
            deleteSuccessText: '@Html.Raw(Localizer["SwalDeleteSuccessText"].Value)',
            deleteErrorTitle: '@Html.Raw(Localizer["SwalDeleteErrorTitle"].Value)',
            deleteErrorText: '@Html.Raw(Localizer["SwalDeleteErrorText"].Value)'
        };

        function handlePostTest(actionType, testId) {
            if (actionType === 'RETAKE') {
                window.location.href = `/TestAttempt/GiaoDienLamBai?id=${testId}&mode=retake`;
                return;
            }

            if (actionType === 'SAVE') {
                Swal.fire({
                    icon: 'success',
                    title: swalTexts.saveSuccessTitle,
                    text: swalTexts.saveSuccessText,
                    timer: 2000,
                    showConfirmButton: false
                }).then(() => {
                    window.location.href = '/Student/Dashboard';
                });
                return;
            }

            if (actionType === 'DELETE') {
                Swal.fire({
                    title: swalTexts.deleteWarnTitle,
                    text: swalTexts.deleteWarnText,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#ef4444',
                    cancelButtonColor: '#64748b',
                    confirmButtonText: swalTexts.btnConfirmDelete,
                    cancelButtonText: swalTexts.btnCancel
                }).then((result) => {
                    if (result.isConfirmed) {
                        fetch(`/TestAttempt/DeleteTestAndQuestions?testId=${testId}`, {
                            method: 'POST'
                        })
                        .then(res => res.json())
                        .then(data => {
                            if (data.success) {
                                Swal.fire(swalTexts.deleteSuccessTitle, swalTexts.deleteSuccessText, 'success')
                                .then(() => {
                                    window.location.href = '/Student/Dashboard';
                                });
                            } else {
                                Swal.fire(swalTexts.deleteErrorTitle, swalTexts.deleteErrorText + data.message, 'error');
                            }
                        });
                    }
                });
            }
        }
    </script>
}