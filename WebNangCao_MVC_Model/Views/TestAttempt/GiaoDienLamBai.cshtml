@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<WebNangCao_MVC_Model.SharedResource> Localizer
@model WebNangCao_MVC_Model.Models.Exam

@{
    ViewData["Title"] = Localizer["ExamAttemptTitle"];
    Layout = null;

    var totalQs = Model?.Questions?.Count ?? 0;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <script src="https://unpkg.com/lucide@latest"></script>
    <link rel="stylesheet" href="~/css/GiaoDienLamBai.css" />
</head> 
<body>
    <form id="examForm">
        @Html.AntiForgeryToken()
        <input type="hidden" id="ExamId" value="@Model?.Id"/>
        <header class="test-header">
            <div class="header-title">
                <h1>@Model?.Title</h1>
                <p>@Localizer["TimeLabel"] @Model?.Duration @Localizer["Minutes"]</p>
            </div>
            <div class="header-actions">
                <div class="timer-badge">
                    <i data-lucide="clock" width="20" height="20"></i>
                    <span id="countdownDisplay">00:00</span>
                </div>
                <button type="button" class="btn-submit" onclick="submitExam()">
                    <i data-lucide="send" width="16" height="16"></i>
                    <span>@Localizer["SubmitExam"]</span>
                </button>
            </div>
        </header>

        <main class="test-container">
            <div class="main-content">
                <div class="card">
                    <div class="progress-header">
                        <span>@Localizer["Progress"] 0/@totalQs @Localizer["InstExamQuestions"]</span>
                        <span class="percent">0%</span>
                    </div>
                    <div class="progress-track">
                        <div class="progress-fill" style="width: 0%"></div>
                    </div>
                </div>

                @{
                    int qIdx = 1;
                }
                @if (Model?.Questions != null)
                {
                    foreach (var question in Model.Questions)
                    {
                        <div class="card question-block" id="question-block-@qIdx" style='display: @(qIdx == 1 ? "block" : "none");'>
                            <div class="question-header">
                                <div class="question-title-wrapper">
                                    <div class="question-number">@qIdx</div>
                                    <div class="question-title">
                                        <h2>@Localizer["QuestionTitle"] @qIdx</h2>
                                        @{
                                            var difficulty = question.Difficulty?.Trim().ToLower();
                                            string difficultyClass = difficulty switch
                                            {
                                                "dễ" or "de" or "easy" => "badge-easy",
                                                "trung bình" or "trung binh" or "medium" => "badge-medium",
                                                "khó" or "kho" or "hard" => "badge-hard",
                                                _ => "badge-default"
                                            };
                                            
                                            // Dịch luôn chữ Độ Khó (nếu cần thiết, dựa vào value)
                                            var diffText = difficulty switch {
                                                "dễ" or "de" or "easy" => Localizer["TabEasy"]?.Value ?? "Dễ",
                                                // ... tạm giữ nguyên text gốc từ DB nếu không setup bảng map
                                                _ => question.Difficulty
                                            };
                                        }
                                        <span class="badge-difficulty @difficultyClass">@question.Difficulty</span>
                                    </div>
                                </div>
                                <button class="btn-flag" type="button" title="@Localizer["FlagForReview"]">
                                    <i data-lucide="flag" width="20" height="20"></i>
                                </button>
                            </div>

                            <div class="question-text">
                                @Html.Raw(question.Content)
                            </div>

                            <div class="answer-list">
                                @if (question.Answers != null)
                                {
                                    char optionLetter = 'A'; 
                                    foreach (var answer in question.Answers)
                                    {
                                        <label class="answer-option">
                                            <input type="radio" name="question_@question.Id" value="@answer.Id">
                                            <span>@optionLetter. @answer.Content</span>
                                        </label>
                                        optionLetter++;
                                    }
                                }
                            </div>

                            <div class="question-nav">
                                <button type="button" class="btn-nav btn-nav-prev" onclick="prevQuestion()" @(qIdx == 1 ? "disabled" : "")>
                                    <i data-lucide="chevron-left" width="18" height="18"></i> @Localizer["PrevQuestion"]
                                </button>

                                <span style="color: var(--text-muted); font-size: 14px; font-weight: 500;">@qIdx / @totalQs</span>

                                <button type="button" class="btn-nav btn-nav-next" onclick="nextQuestion()">
                                    @Localizer["NextQuestion"] <i data-lucide="chevron-right" width="18" height="18"></i>
                                </button>
                            </div>
                        </div>
                        qIdx++;
                    }
                }
            </div>

            <aside class="sidebar card">
                <h3>@Localizer["QuestionList"]</h3>

                <div class="filter-tabs">
                    <button type="button" class="filter-tab active">@Localizer["TabAll"]</button>
                    <button type="button" class="filter-tab">@Localizer["TabDone"]</button>
                    <button type="button" class="filter-tab">@Localizer["TabFlagged"]</button>
                </div>

                <div class="question-grid">
                    @for (int i = 1; i <= totalQs; i++)
                    {
                        <button type="button" class="grid-item @(i == 1 ? "active" : "")" onclick="jumpToQuestion(@i)">@i</button>
                    }
                </div>

                <div class="legend-list">
                    <div class="legend-item">
                        <div class="legend-left">
                            <div class="legend-box box-answered"></div>
                            <span>@Localizer["Answered"]</span>
                        </div>
                        <span class="legend-count">0</span>
                    </div>
                    <div class="legend-item">
                        <div class="legend-left">
                            <div class="legend-box box-unanswered"></div>
                            <span>@Localizer["Unanswered"]</span>
                        </div>
                        <span class="legend-count">@totalQs</span>
                    </div>
                    <div class="legend-item">
                        <div class="legend-left">
                            <i data-lucide="flag" width="14" height="14" style="color: var(--warning-color); fill: var(--warning-color)"></i>
                            <span>@Localizer["Flagged"]</span>
                        </div>
                        <span class="legend-count">0</span>
                    </div>
                </div>
            </aside>
        </main>
    </form>

    <footer class="exam-footer">
        <div class="shortcut-hints">
            <span class="shortcut-title">
                <i class="shortCutIconText" data-lucide="keyboard" width="24" height="24"></i>
                <strong>@Localizer["ShortcutHints"]</strong>
            </span>
            <span class="key-hint"><kbd>1</kbd> - <kbd>9</kbd> @Localizer["HintSelect"]</span>
            <span class="key-hint"><kbd>0</kbd> @Localizer["HintDeselect"]</span>
            <span class="key-hint"><kbd>←</kbd> <kbd>→</kbd> @Localizer["HintNav"]</span>
            <span class="key-hint"><kbd>F</kbd> @Localizer["HintFlag"]</span>
            <span class="key-hint"><kbd>Enter</kbd> @Localizer["HintSubmit"]</span>
            <span class="key-hint"><kbd>Esc</kbd> @Localizer["HintCancel"]</span>
        </div>
    </footer>

    <div id="submitModal" class="modal-overlay" style="display: none;">
        <div class="modal-content">
            <div class="modal-header">
                <i data-lucide="circle-alert" class="icon-warning" width="24" height="24"></i>
                <h2>@Localizer["ConfirmSubmitTitle"]</h2>
            </div>

            <div class="modal-body">
                <p class="modal-desc">@Localizer["ConfirmSubmitDesc"]</p>

                <div class="stats-box">
                    <div class="stat-row">
                        <span>@Localizer["Answered"]:</span>
                        <span id="modal-answered" class="stat-value">0/@totalQs @Localizer["InstExamQuestions"]</span>
                    </div>
                    <div class="stat-row">
                        <span>@Localizer["Unanswered"]:</span>
                        <span id="modal-unanswered" class="stat-value">@totalQs @Localizer["InstExamQuestions"]</span>
                    </div>
                    <div class="stat-row">
                        <span>@Localizer["Flagged"]:</span>
                        <span id="modal-flagged" class="stat-value">0 @Localizer["InstExamQuestions"]</span>
                    </div>
                </div>

                <div id="modal-warning-box" class="warning-box">
                    <i data-lucide="circle-alert" width="18" height="18"></i>
                    <span id="modal-warning-text">Bạn còn @totalQs câu chưa trả lời. Bài làm sẽ không thể chỉnh sửa sau khi nộp.</span>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-cancel" onclick="closeSubmitModal()">@Localizer["ContinueExam"]</button>
                <button type="button" class="btn-confirm-submit" onclick="executeSubmit()">
                    <i data-lucide="send" width="16" height="16"></i> @Localizer["SubmitExam"]
                </button>
            </div>
        </div>
    </div>

    <div id="resultModal" class="modal-overlay" style="display: none;">
        <div class="modal-content result-content">
            <div class="result-header">
                <div class="success-icon-wrapper">
                    <i data-lucide="check-circle" width="36" height="36"></i>
                </div>
                <h2>@Localizer["SubmitSuccessTitle"]</h2>
                <p class="text-muted">@Localizer["SubmitSuccessDesc"]</p>
            </div>

            <div class="result-body">
                <div class="score-circle">
                    <span id="result-score" class="score-number">0.0</span>
                    <span class="score-label">@Localizer["ScoreLabel"]</span>
                </div>

                <div class="result-details">
                    <div class="detail-row" style="border-bottom: 1px dashed var(--border-color); padding-bottom: 12px; margin-bottom: 12px;">
                        <span>@Localizer["TotalCorrect"]</span>
                        <span id="result-correct" class="detail-value text-success">0/0</span>
                    </div>

                    <div class="difficulty-breakdown" style="display: flex; flex-direction: column; gap: 8px;">
                        <div class="detail-row" style="font-size: 14px;">
                            <span><span style="color: #22c55e; margin-right: 6px;">●</span> @Localizer["LevelEasy"]</span>
                            <span id="result-easy" class="detail-value" style="font-weight: 600;">0 @Localizer["InstExamQuestions"]</span>
                        </div>
                        <div class="detail-row" style="font-size: 14px;">
                            <span><span style="color: #f59e0b; margin-right: 6px;">●</span> @Localizer["LevelMedium"]</span>
                            <span id="result-medium" class="detail-value" style="font-weight: 600;">0 @Localizer["InstExamQuestions"]</span>
                        </div>
                        <div class="detail-row" style="font-size: 14px;">
                            <span><span style="color: #ef4444; margin-right: 6px;">●</span> @Localizer["LevelHard"]</span>
                            <span id="result-hard" class="detail-value" style="font-weight: 600;">0 @Localizer["InstExamQuestions"]</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn-primary" onclick="goToResultPage()">
                    @Localizer["ViewDetails"] <i data-lucide="arrow-right" width="16" height="16"></i>
                </button>
            </div>
        </div>
    </div>
    
    <script>
        const currentExamId = @Model.Id; 
        const TIME_LIMIT_MINUTES = @(Model?.Duration ?? 0);
        const IS_ANTI_CHEAT = '@(ViewBag.AntiCheat ?? false)'.toLowerCase() === 'true';
        const IS_SHUFFLE_Q = '@(ViewBag.ShuffleQ ?? false)'.toLowerCase() === 'true';

        // CHUẨN BỊ TỪ ĐIỂN CHO FILE GiaoDienLamBai.js
        window.AppTranslations = window.AppTranslations || {};
        window.AppTranslations.WarningUnanswered = '@Html.Raw(Localizer["WarningUnanswered"].Value)';
        window.AppTranslations.InstExamQuestions = '@Localizer["InstExamQuestions"]';
    </script>

    @{
        var totalSec = (Model?.Duration ?? 0) * 60;
        double maxAllowedSec = totalSec;
        if (Model?.EndTime != null)
        {
            var timeDiff = (DateTime)Model.EndTime - DateTime.Now;
            if (timeDiff.TotalSeconds > 0 && timeDiff.TotalSeconds < totalSec)
            {
                maxAllowedSec = timeDiff.TotalSeconds;
            }
            else if (timeDiff.TotalSeconds <= 0)
            {
                maxAllowedSec = 0; 
            }
        }
    }
    
    <script src="~/js/GiaoDienLamBai.js" asp-append-version="true"></script>

</body>
</html>